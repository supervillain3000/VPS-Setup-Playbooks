version: "3.8"

services:
  flowise:
    image: "{{ flowise_image }}"
    restart: unless-stopped
    env_file:
      - .env
    ports:
      - "127.0.0.1:{{ flowise_port }}:{{ flowise_port }}"
    volumes:
      - flowise_data:/root/.flowise
    entrypoint: /bin/sh -c "sleep 3; flowise start"

volumes:
  flowise_data:
